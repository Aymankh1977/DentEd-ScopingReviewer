"""
DentEd-ScopingReviewer™ — Streamlit UI
========================================
Wraps the platform engine in a publisher-demo-ready interface.

Tabs:
  1. New Review          — start project, upload PDFs, run cascade
  2. Manuscript Critique — upload a manuscript + reference PDFs, audit
  3. Project Workspace   — load existing projects, view sections, export
  4. Originality Audit   — run novelty audit against project/folder/web

Run from project root:
    streamlit run app.py
"""

from __future__ import annotations

import json
import logging
import tempfile
from pathlib import Path

import streamlit as st

# Make `app/` importable when running via streamlit run app.py
import sys
sys.path.insert(0, str(Path(__file__).resolve().parent))

from app.agents.orchestrator import (
    Orchestrator, ReviewMode, SectionStatus, PRISMA_SCR_SECTIONS,
)
from app.agents.api_client_manager import get_manager
from app.agents.originality_auditor import (
    OriginalityAuditor, audit_project_manuscript,
)
from app.prompts import SECTION_PROMPTS

logging.basicConfig(level=logging.INFO)

APP_VERSION = "0.1.0"
WORKSPACE_ROOT = Path("data/processed")
EXPORT_ROOT = Path("data/exports")
WORKSPACE_ROOT.mkdir(parents=True, exist_ok=True)
EXPORT_ROOT.mkdir(parents=True, exist_ok=True)

# ---------------------------------------------------------------------------
# Page config + theme
# ---------------------------------------------------------------------------
st.set_page_config(
    page_title="DentEd-ScopingReviewer™",
    page_icon="🦷",
    layout="wide",
    initial_sidebar_state="expanded",
)

st.markdown("""
<style>
.stApp { background-color: #fbf8f3; }
h1, h2, h3 { font-family: 'Playfair Display', Georgia, serif; color: #2c4a5a; }
[data-testid="stSidebar"] { background-color: #2c4a5a; }
[data-testid="stSidebar"] h1, [data-testid="stSidebar"] h2,
[data-testid="stSidebar"] h3, [data-testid="stSidebar"] p,
[data-testid="stSidebar"] label { color: #f2ede4 !important; }
.metric-pill {
    display: inline-block; padding: 4px 12px; border-radius: 12px;
    font-size: 0.85em; margin: 2px; font-weight: 600;
}
.pill-approve { background-color: #d4edda; color: #155724; }
.pill-revise  { background-color: #fff3cd; color: #856404; }
.pill-reject  { background-color: #f8d7da; color: #721c24; }
.pill-pending { background-color: #e9ecef; color: #495057; }
</style>
""", unsafe_allow_html=True)

# ---------------------------------------------------------------------------
# Session state
# ---------------------------------------------------------------------------
if "active_project_id" not in st.session_state:
    st.session_state.active_project_id = None
if "orch" not in st.session_state:
    st.session_state.orch = Orchestrator(auto_critique=True)


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
def _save_uploaded(file, prefix: str = "upload") -> str:
    """Persist an uploaded file to a temp path and return absolute path."""
    suffix = Path(file.name).suffix or ".pdf"
    tmp = tempfile.NamedTemporaryFile(
        delete=False, suffix=suffix, prefix=f"{prefix}_"
    )
    tmp.write(file.getbuffer())
    tmp.close()
    return tmp.name


def _list_projects() -> list[str]:
    return sorted([p.name for p in WORKSPACE_ROOT.iterdir() if p.is_dir()],
                  reverse=True)


def _verdict_pill(verdict: str, score: int | None = None) -> str:
    label = verdict.upper() if verdict else "—"
    if score is not None:
        label = f"{score}/100 · {label}"
    css = {
        "approve": "pill-approve",
        "revise":  "pill-revise",
        "reject":  "pill-reject",
        "novel":   "pill-approve",
        "incremental": "pill-revise",
        "derivative":  "pill-reject",
        "duplicative": "pill-reject",
    }.get(verdict, "pill-pending")
    return f'<span class="metric-pill {css}">{label}</span>'


# ---------------------------------------------------------------------------
# Sidebar
# ---------------------------------------------------------------------------
with st.sidebar:
    st.title("🦷 DentEd-ScopingReviewer™")
    st.caption(f"v{APP_VERSION} · PRISMA-ScR-compliant")
    st.divider()

    st.subheader("API status")
    try:
        for role, info in get_manager().status_report().items():
            flag = "✓" if info["configured"] else "✗"
            st.caption(f"{flag} **{role}** — {info['model']}")
    except Exception as e:
        st.error(f"API not configured: {e}")

    st.divider()
    st.subheader("Active project")
    projects = _list_projects()
    if projects:
        selected = st.selectbox(
            "Load existing project",
            options=["— none —"] + projects,
            index=(projects.index(st.session_state.active_project_id) + 1
                   if st.session_state.active_project_id in projects else 0),
        )
        if selected != "— none —":
            st.session_state.active_project_id = selected
            st.caption(f"Loaded: `{selected}`")
    else:
        st.caption("No projects yet — create one in **New Review**.")


# ---------------------------------------------------------------------------
# Tabs
# ---------------------------------------------------------------------------
tab1, tab2, tab3, tab4 = st.tabs([
    "📝 New Review",
    "🔍 Manuscript Critique",
    "📚 Project Workspace",
    "✨ Originality Audit",
])


# ============================================================================
# TAB 1: New Review
# ============================================================================
with tab1:
    st.header("Generate a new scoping review")
    st.caption("PRISMA-ScR-compliant, evidence-anchored, auto-critiqued.")

    with st.form("new_project"):
        col1, col2 = st.columns(2)
        with col1:
            rq = st.text_area(
                "Research question",
                placeholder="What empirical evidence informs...",
                height=80,
            )
            population = st.text_input("Population (P)")
            concept = st.text_input("Concept (C)")
            context = st.text_input("Context (C)")
        with col2:
            uploads = st.file_uploader(
                "Upload corpus PDFs",
                accept_multiple_files=True,
                type=["pdf"],
            )
            auto_critique = st.checkbox(
                "Auto-critique each section (recommended)", value=True
            )
            full_cascade = st.checkbox(
                "Cascade through all 21 sections", value=True
            )

        submit = st.form_submit_button("🚀 Start review", type="primary")

    if submit:
        if not (rq and population and concept and context and uploads):
            st.error("Fill all four fields and upload at least one PDF.")
        else:
            orch = Orchestrator(auto_critique=auto_critique)
            with st.spinner("Starting project..."):
                project = orch.start_project(
                    mode=ReviewMode.GENERATE,
                    research_question=rq, population=population,
                    concept=concept, context=context,
                )
                st.session_state.active_project_id = project.project_id

            st.success(f"Project `{project.project_id}` created.")

            progress = st.progress(0.0, text="Registering sources…")
            for i, f in enumerate(uploads):
                path = _save_uploaded(f, "corpus")
                orch.register_source(project, path, role="corpus",
                                     filename=f.name)
                progress.progress((i + 1) / max(len(uploads), 1),
                                  text=f"Registered: {f.name}")

            with st.spinner(f"Extracting {len(uploads)} PDFs..."):
                orch.extract_all(project)

            included = sum(
                1 for s in project.sources.values()
                if (s.extracted_chart or {}).get("relevance", {}).get(
                    "inclusion_recommendation") == "include"
            )
            st.info(f"Extraction complete — {included}/{len(uploads)} marked for inclusion.")

            if full_cascade:
                with st.spinner("Cascading through PRISMA-ScR sections…"):
                    drafted = orch.draft_all_ready(project, max_iterations=30)
                st.success(f"Drafted {len(drafted)} sections.")
            st.rerun()


# ============================================================================
# TAB 2: Manuscript Critique
# ============================================================================
with tab2:
    st.header("Critique an existing manuscript")
    st.caption("Upload a draft manuscript and reference corpus. The platform "
               "audits per PRISMA-ScR rubric + flags originality issues.")

    with st.form("critique_form"):
        col1, col2 = st.columns(2)
        with col1:
            manuscript = st.file_uploader(
                "Upload manuscript (PDF)", type=["pdf"], key="ms"
            )
            mode_label = st.radio(
                "Reference corpus",
                ["Folder of comparison PDFs (upload below)",
                 "Use an existing project's corpus",
                 "Web/training knowledge only (no PDFs)"],
            )
        with col2:
            comparison_files = st.file_uploader(
                "Comparison PDFs (only used if first option selected)",
                accept_multiple_files=True, type=["pdf"], key="comp",
            )
            existing_project = st.selectbox(
                "Or pick existing project (if second option selected)",
                options=["— none —"] + _list_projects(),
            )

        go = st.form_submit_button("🔍 Audit manuscript", type="primary")

    if go:
        if not manuscript:
            st.error("Upload a manuscript PDF.")
        else:
            st.info("Manuscript critique mode runs the extractor on the "
                    "manuscript, then the originality auditor. "
                    "PRISMA-ScR critique of an *uploaded* manuscript "
                    "(section-by-section, not generation) is a future "
                    "enhancement — for now this tab focuses on originality.")
            st.warning("Use **Originality Audit** tab for the working "
                       "version of this workflow with finer controls.")


# ============================================================================
# TAB 3: Project Workspace
# ============================================================================
with tab3:
    st.header("Project workspace")
    pid = st.session_state.active_project_id
    if not pid:
        st.info("Load a project from the sidebar.")
    else:
        orch = st.session_state.orch
        try:
            project = orch.load(pid)
        except Exception as e:
            st.error(f"Could not load project: {e}")
            st.stop()

        st.subheader(f"`{pid}`")
        c1, c2, c3, c4 = st.columns(4)
        with c1:
            st.metric("Sources", len(project.sources))
        with c2:
            drafted = sum(1 for s in project.sections.values() if s.draft)
            st.metric("Drafted", f"{drafted}/21")
        with c3:
            critiqued = sum(
                1 for s in project.sections.values()
                if s.status in {SectionStatus.CRITIQUED, SectionStatus.APPROVED}
            )
            st.metric("Approved", critiqued)
        with c4:
            scores = [
                (s.critique or {}).get("overall_score")
                for s in project.sections.values()
                if s.critique and (s.critique or {}).get("overall_score")
            ]
            if scores:
                st.metric("Mean score", f"{sum(scores) / len(scores):.0f}/100")

        st.caption(f"**Research question:** {project.research_question}")

        # Section table
        st.subheader("Sections")
        for entry in PRISMA_SCR_SECTIONS:
            sid = entry["id"]
            state = project.sections.get(sid)
            if not state:
                continue
            crit = state.critique or {}
            score = crit.get("overall_score")
            verdict = crit.get("verdict", "")

            with st.expander(
                f"**{sid}** · {state.status.value} · {state.word_count}w "
                f"{('— ' + str(score) + '/100') if score else ''}"
            ):
                if score is not None:
                    st.markdown(_verdict_pill(verdict, score),
                                unsafe_allow_html=True)

                if state.draft:
                    st.markdown(state.draft)
                else:
                    st.caption(f"_Status: {state.status.value}_")

                if crit:
                    with st.expander("Critic feedback"):
                        if crit.get("strengths"):
                            st.markdown("**Strengths**")
                            for s in crit["strengths"]:
                                st.markdown(f"- {s}")
                        if crit.get("revision_notes"):
                            st.markdown("**Revision notes**")
                            for i, n in enumerate(crit["revision_notes"], 1):
                                st.markdown(f"{i}. {n}")

                if state.status == SectionStatus.REVISION_REQUESTED:
                    if st.button(f"🔁 Revise {sid}", key=f"rev_{sid}"):
                        with st.spinner("Revising…"):
                            orch.revise_section(project, sid)
                        st.rerun()

        st.divider()
        col_a, col_b = st.columns(2)
        with col_a:
            if st.button("📄 Export full manuscript"):
                from tests.export_review import export
                out = export(pid)
                st.success(f"Exported to `{out}`")
                with open(out) as f:
                    st.download_button("Download .md",
                                       data=f.read(),
                                       file_name=f"{pid}.md",
                                       mime="text/markdown")
        with col_b:
            if st.button("🔁 Run all revision-requested sections"):
                with st.spinner("Revising all flagged sections…"):
                    for sid, st_ in project.sections.items():
                        if st_.status == SectionStatus.REVISION_REQUESTED:
                            orch.revise_section(project, sid)
                st.rerun()


# ============================================================================
# TAB 4: Originality Audit
# ============================================================================
with tab4:
    st.header("Originality audit")
    st.caption("Detect conceptual overlap between a manuscript and a "
               "reference corpus. Distinguishes citation from duplication.")

    pid = st.session_state.active_project_id
    if not pid:
        st.info("Load a project from the sidebar — the audit runs against "
                "the project's drafted sections.")
    else:
        mode = st.radio(
            "Reference corpus mode",
            ["project (reuse existing corpus, free)",
             "folder (upload comparison PDFs)",
             "web (Claude's training knowledge)"],
        )
        granularity = st.radio(
            "Report granularity",
            ["both", "section", "whole"],
            horizontal=True,
        )

        folder_files = None
        if "folder" in mode:
            folder_files = st.file_uploader(
                "Comparison PDFs", accept_multiple_files=True, type=["pdf"],
            )

        if st.button("✨ Run audit", type="primary"):
            corpus_mode = mode.split(" ")[0]
            tmp_folder = None
            if corpus_mode == "folder":
                if not folder_files:
                    st.error("Upload at least one comparison PDF.")
                    st.stop()
                tmp_folder = Path(tempfile.mkdtemp(prefix="audit_corpus_"))
                for f in folder_files:
                    (tmp_folder / f.name).write_bytes(f.getbuffer())

            with st.spinner("Auditing…"):
                result = audit_project_manuscript(
                    project_id=pid,
                    corpus_mode=corpus_mode,
                    folder_path=str(tmp_folder) if tmp_folder else None,
                    granularity=granularity,
                )

            if result.error:
                st.error(result.error)
            else:
                c1, c2 = st.columns([1, 2])
                with c1:
                    st.metric("Overall score", f"{result.overall_score}/100")
                    st.markdown(_verdict_pill(result.overall_verdict),
                                unsafe_allow_html=True)
                    st.caption(f"Corpus size: {result.reference_corpus_size}")
                with c2:
                    st.markdown(f"**Summary:** {result.overall_summary}")

                if result.section_reports:
                    st.subheader("Per-section novelty")
                    for sr in result.section_reports:
                        cols = st.columns([3, 1, 1])
                        cols[0].write(sr.section_id)
                        cols[1].write(f"{sr.novelty_score}/100")
                        cols[2].markdown(_verdict_pill(sr.verdict),
                                         unsafe_allow_html=True)
                        if sr.overlap_matches:
                            with st.expander(
                                f"{len(sr.overlap_matches)} overlap flag(s) — {sr.section_id}"
                            ):
                                for m in sr.overlap_matches:
                                    st.markdown(
                                        f"- **[{m.overlap_type}] vs "
                                        f"{m.reference_label}** "
                                        f"({m.severity}): "
                                        f"{m.overlap_description}"
                                    )

                # Save report
                out = EXPORT_ROOT / f"{pid}_originality.json"
                out.write_text(json.dumps(result.to_dict(), indent=2,
                                          ensure_ascii=False))
                st.success(f"Report saved to `{out}`")
